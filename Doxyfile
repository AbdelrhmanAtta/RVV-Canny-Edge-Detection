# --- Project Information ---
PROJECT_NAME           = "RVV Canny Edge Detection"
PROJECT_NUMBER         = 1.0
OUTPUT_DIRECTORY       = .
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES

# --- Input Configuration (CRITICAL FIX) ---
# Point to your source, include, and README
INPUT                  = README.md inc src
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.hpp *.h *.c *.md
EXCLUDE                = build .venv tests scripts

# --- Main Page Settings ---
# Use your README.md as the landing page
USE_MDRIP              = YES
MAINPAGE_LOG           = README.md

# --- Extraction Settings ---
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

# --- Build Settings ---
# Enable modern C++ parsing
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = NO

# --- Diagram Generation (Graphviz) ---
# Since your GitHub Action installs graphviz, turn these on!
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_PATH               = /usr/bin/dot

# --- HTML Output Settings ---
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html

# --- Math Support (For your Canny/Gaussian math) ---
USE_MATHJAX            = YES
MATHJAX_FORMAT         = HTML-CSS