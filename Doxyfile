# --- Project Information ---
PROJECT_NAME           = "RVV Canny Edge Detection"
PROJECT_NUMBER         = 1.0
OUTPUT_DIRECTORY       = .
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES

# --- Input Configuration ---
INPUT                  = README.md inc src tools
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.hpp *.h *.c *.md *.py
EXCLUDE                = build .venv tests

# --- Main Page Settings (Fixed) ---
USE_MDFILE_AS_MAINPAGE = README.md

# --- Extraction Settings ---
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

# --- Build Settings ---
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = NO
NUM_PROC_THREADS       = 0

# --- Diagram Generation (Graphviz) ---
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_NUM_THREADS        = 4
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_PATH               = /usr/bin/dot

# --- HTML Output Settings (Doxygen Awesome) ---
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = TOGGLE
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES
HTML_EXTRA_STYLESHEET  = external/doxygen-awesome-css/doxygen-awesome.css

# --- Math Support ---
USE_MATHJAX            = YES
MATHJAX_FORMAT         = HTML-CSS
MATHJAX_RELPATH        = 

# --- Source Browsing ---
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES